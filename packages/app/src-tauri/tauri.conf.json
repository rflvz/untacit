{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "untacit",
  "version": "0.1.0",
  "identifier": "dev.untacit.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm bundle:sidecar"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "untacit",
        "width": 1400,
        "height": 900,
        "minWidth": 760,
        "minHeight": 520,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "publisher": "untacit",
    "shortDescription": "Grafo del conocimiento tácito de tu organización",
    "longDescription": "untacit captura el conocimiento tácito de una organización como un grafo versionado en git: revisión de merges y conflictos, drift entre versiones y entrevistas agénticas, todo en local.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../sidecar/dist/": "sidecar/"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Spanish", "English"],
        "displayLanguageSelector": true
      }
    }
  }
}

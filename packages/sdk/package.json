{
  "name": "@untacit/sdk",
  "version": "0.1.0",
  "license": "MIT",
  "description": "untacit SDK: stable programmatic surface over a graph repo — context retrieval, graph queries, diff, batch import and extraction",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@untacit/core": "workspace:*",
    "@untacit/extractors": "workspace:*",
    "@untacit/mcp": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
